#!/usr/bin/env bash
# gh-clanker — gh CLI wrapper that appends a suffix to PR/issue/release bodies.
# Activated when GH_CLANKER_SUFFIX is set (its value IS the suffix, including leading newlines).

# ── Early gate: passthrough if suffix is unset/empty ──
# Checked before PATH scan so non-agent shells pay zero overhead.
if [[ -z "${GH_CLANKER_SUFFIX:-}" ]]; then
  _self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/gh"
  IFS=: read -ra _path_dirs <<< "$PATH"
  for _d in "${_path_dirs[@]}"; do
    [[ -x "$_d/gh" && "$(cd "$_d" && pwd)/gh" != "$_self" ]] && exec "$_d/gh" "$@"
  done
  echo "gh-clanker: real gh not found in PATH" >&2
  exit 1
fi

# ── Find the real gh (skip ourselves) ──
_self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/gh"
_real_gh=""
IFS=: read -ra _path_dirs <<< "$PATH"
for _d in "${_path_dirs[@]}"; do
  [[ -x "$_d/gh" && "$(cd "$_d" && pwd)/gh" != "$_self" ]] && { _real_gh="$_d/gh"; break; }
done

if [[ -z "$_real_gh" ]]; then
  echo "gh-clanker: real gh not found in PATH" >&2
  exit 1
fi

_suffix="$GH_CLANKER_SUFFIX"
_suffix_trimmed="${_suffix#"${_suffix%%[![:space:]]*}"}"

# ── Temp-file cleanup ──
_temp_files=()
_cleanup() { (( ${#_temp_files[@]} )) && rm -f -- "${_temp_files[@]}"; }
trap _cleanup EXIT

# ── Helpers ──
# Sets _result instead of printing, to avoid subshell overhead from $(...)
_append_suffix() {
  local body="$1"
  if [[ "$body" == *"$_suffix_trimmed"* ]]; then
    _result="$body"
  elif [[ -z "$body" ]]; then
    _result="$_suffix_trimmed"
  else
    _result="$body$_suffix"
  fi
}

# ── Route: determine if we intercept ──
_cmd="${1:-}"
_sub="${2:-}"

case "$_cmd:$_sub" in
  pr:create)      _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="--web -w --editor -e --dry-run" ;;
  pr:edit)        _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="" ;;
  pr:comment)     _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="--web -w --editor -e" ;;
  pr:review)      _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="" ;;
  pr:merge)       _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="" ;;
  issue:create)   _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="--web -w --editor -e" ;;
  issue:edit)     _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="" ;;
  issue:comment)  _tf="--body"  _ts="-b" _ff="--body-file"  _fs="-F" _skip="--web -w --editor -e" ;;
  release:create) _tf="--notes" _ts="-n" _ff="--notes-file" _fs=""   _skip="--generate-notes --notes-from-tag" ;;
  release:edit)   _tf="--notes" _ts="-n" _ff="--notes-file" _fs=""   _skip="" ;;
  *)              exec "$_real_gh" "$@" ;;
esac

# Check skip flags
for _a in "$@"; do
  for _s in $_skip; do
    [[ "$_a" == "$_s" ]] && exec "$_real_gh" "$@"
  done
done

# ── Rewrite arguments ──
_args=("$@")
_rw=()
_changed=0
_supplied=0
_i=0

_rewrite_file() {
  local src="$1"
  if [[ "$src" == "-" || -f "$src" ]]; then
    local tmp; tmp="$(mktemp -t gh-clanker.XXXXXX)"; _temp_files+=("$tmp")
    local bt; if [[ "$src" == "-" ]]; then bt="$(cat)"; else bt="$(<"$src")"; fi
    _append_suffix "$bt"; printf '%s' "$_result" > "$tmp"
    _result="$tmp"; _changed=1
  else
    _result="$src"
  fi
}

while (( _i < ${#_args[@]} )); do
  _a="${_args[_i]}"

  if [[ "$_a" == "$_tf" || ( -n "$_ts" && "$_a" == "$_ts" ) ]]; then
    _supplied=1; _rw+=("$_a")
    if (( _i + 1 < ${#_args[@]} )); then
      (( _i++ )); _append_suffix "${_args[_i]}"; _rw+=("$_result"); _changed=1
    fi

  elif [[ "$_a" == "${_tf}="* ]]; then
    _supplied=1; _append_suffix "${_a#"${_tf}="}"; _rw+=("${_tf}=$_result"); _changed=1

  elif [[ "$_a" == "$_ff" || ( -n "$_fs" && "$_a" == "$_fs" ) ]]; then
    _supplied=1; _rw+=("$_a")
    if (( _i + 1 < ${#_args[@]} )); then
      (( _i++ )); _rewrite_file "${_args[_i]}"; _rw+=("$_result")
    fi

  elif [[ "$_a" == "${_ff}="* ]]; then
    _supplied=1; _rewrite_file "${_a#"${_ff}="}"; _rw+=("${_ff}=$_result")

  else
    _rw+=("$_a")
  fi

  (( _i++ ))
done

# ── Execute ──
_rc=0
if (( _changed )); then
  "$_real_gh" "${_rw[@]}" || _rc=$?
else
  "$_real_gh" "$@" || _rc=$?
fi

# ── Post-create fixup: pr create without explicit body ──
if (( _rc == 0 )) && [[ "$_cmd:$_sub" == "pr:create" ]] && (( ! _supplied )); then
  _pb="$("$_real_gh" pr view --json body --jq .body 2>/dev/null || true)"
  _append_suffix "${_pb:-}"
  if [[ "$_result" != "${_pb:-}" ]]; then
    "$_real_gh" pr edit --body "$_result" >/dev/null 2>&1 || true
  fi
fi

exit "$_rc"
